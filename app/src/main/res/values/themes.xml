<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.GeradorPlus" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryVariant">@color/colorPrimaryVariant</item>
        <item name="colorOnPrimary">@color/colorOnPrimary</item>
        <item name="colorSecondary">@color/colorSecondary</item>
        <item name="colorOnSecondary">@color/colorOnSecondary</item>
        <item name="android:colorBackground">@color/bg_dark</item>
        <item name="colorSurface">@color/bg_surface</item>
        <item name="colorError">@color/colorError</item>
        <item name="android:windowBackground">@color/bg_dark</item>
        <item name="android:statusBarColor">@color/bg_dark</item>
        <item name="android:navigationBarColor">@color/bg_surface</item>

        <!-- TextInputLayout global style -->
        <item name="textInputStyle">@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox</item>

        <!-- Chip style -->
        <item name="chipStyle">@style/Widget.GeradorPlus.Chip</item>

        <!-- Material Card -->
        <item name="materialCardViewStyle">@style/Widget.GeradorPlus.Card</item>
    </style>

    <!-- Splash theme with no ActionBar -->
    <style name="Theme.GeradorPlus.Splash" parent="Theme.GeradorPlus">
        <item name="android:windowBackground">@color/bg_dark</item>
        <item name="android:windowFullscreen">false</item>
    </style>

    <!-- Chips -->
    <style name="Widget.GeradorPlus.Chip" parent="Widget.MaterialComponents.Chip.Action">
        <item name="android:textColor">@color/white</item>
        <item name="chipBackgroundColor">@color/bg_card</item>
        <item name="chipStrokeColor">@color/accent_red</item>
        <item name="chipStrokeWidth">1dp</item>
        <item name="checkedIconVisible">false</item>
    </style>

    <!-- Card -->
    <style name="Widget.GeradorPlus.Card" parent="Widget.MaterialComponents.CardView">
        <item name="cardBackgroundColor">@color/bg_surface</item>
        <item name="cardCornerRadius">12dp</item>
        <item name="cardElevation">2dp</item>
    </style>

    <!-- Bottom Navigation -->
    <style name="Widget.GeradorPlus.BottomNav" parent="Widget.MaterialComponents.BottomNavigationView">
        <item name="android:background">@color/bg_surface</item>
        <item name="itemIconTint">@color/nav_item_color</item>
        <item name="itemTextColor">@color/nav_item_color</item>
    </style>

    <!-- Toolbar -->
    <style name="Widget.GeradorPlus.Toolbar" parent="Widget.MaterialComponents.Toolbar.Primary">
        <item name="android:background">@color/bg_surface</item>
        <item name="titleTextColor">@color/white</item>
        <item name="navigationIconTint">@color/white</item>
    </style>

</resources>
